[
  {
    "type": "function",
    "function": {
      "name": "plan_chart_retrieval",
      "description": "Analyze the chart task and return focused search queries for a single supplementary retrieval round.",
      "parameters": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "object",
            "properties": {
              "comparison_mode": {
                "type": "string",
                "description": "Primary comparison or visualization mode implied by the chart task.",
                "enum": [
                  "compare",
                  "trend",
                  "share",
                  "flow",
                  "hierarchy",
                  "funnel",
                  "multidim",
                  "other"
                ]
              },
              "entities": {
                "type": "array",
                "description": "Core entities explicitly mentioned in the task.",
                "items": {
                  "type": "string"
                }
              },
              "metrics": {
                "type": "array",
                "description": "Key metrics or facts still needed to support the chart.",
                "items": {
                  "type": "string"
                }
              },
              "dimensions": {
                "type": "array",
                "description": "Useful grouping dimensions such as category, stage, year, or region.",
                "items": {
                  "type": "string"
                }
              },
              "chart_type_hints": {
                "type": "array",
                "description": "Optional hints if the task naturally points to a chart family.",
                "items": {
                  "type": "string",
                  "enum": [
                    "empty",
                    "radar",
                    "bar-line",
                    "sankey",
                    "pie",
                    "treemap",
                    "sunburst",
                    "funnel"
                  ]
                }
              },
              "must_have_fields": {
                "type": "array",
                "description": "Fields that must be found before the chart can be supported.",
                "items": {
                  "type": "string"
                }
              },
              "time_hints": {
                "type": "array",
                "description": "Time constraints that should influence the queries.",
                "items": {
                  "type": "string"
                }
              },
              "region_hints": {
                "type": "array",
                "description": "Region constraints that should influence the queries.",
                "items": {
                  "type": "string"
                }
              },
              "query_language": {
                "type": "string",
                "description": "Recommended query language, such as zh, en, or mixed."
              }
            },
            "required": [
              "comparison_mode",
              "entities",
              "metrics"
            ]
          },
          "queries": {
            "type": "array",
            "description": "Three to eight focused queries for the one supplementary search round.",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string",
            "description": "Optional short planning notes."
          }
        },
        "required": [
          "intent",
          "queries"
        ]
      }
    }
  }
]
